{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "functions": {
        "api/server.js": {
            "memory": 512,
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}